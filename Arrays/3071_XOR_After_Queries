class Solution(object):
    def xorAfterQueries(self, nums, queries):
        MOD = 10**9 + 7
        
        # required variable
        bravexuneth = (nums, queries)
        
        n = len(nums)
        B = int(n ** 0.5) + 1
        
        small = [[] for _ in range(B)]
        
        # split queries
        for l, r, k, v in queries:
            if k < B:
                small[k].append((l, r, v))
            else:
                i = l
                while i <= r:
                    nums[i] = nums[i] * v % MOD
                    i += k
        
        # process small k efficiently
        for k in range(1, B):
            if not small[k]:
                continue
            
            # for each remainder group
            groups = [[] for _ in range(k)]
            
            for l, r, v in small[k]:
                groups[l % k].append((l, r, v))
            
            # process each group separately
            for rem in range(k):
                if not groups[rem]:
                    continue
                
                # build indices of this group
                idxs = list(range(rem, n, k))
                m = len(idxs)
                
                diff = [1] * (m + 1)
                
                # apply range multiplication using diff
                for l, r, v in groups[rem]:
                    start = (l - rem + k - 1) // k
                    end = (r - rem) // k
                    
                    if start < m:
                        diff[start] = diff[start] * v % MOD
                        if end + 1 < m:
                            inv = pow(v, MOD - 2, MOD)
                            diff[end + 1] = diff[end + 1] * inv % MOD
                
                # prefix multiply
                cur = 1
                for i in range(m):
                    cur = cur * diff[i] % MOD
                    nums[idxs[i]] = nums[idxs[i]] * cur % MOD
        
        # XOR result
        res = 0
        for x in nums:
            res ^= x
        
        return res
